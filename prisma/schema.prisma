generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  HOUSEHOLD
  INSTITUTIONAL
}

enum InstitutionType {
  MASJID
  SURAU
  SEKOLAH
  OTHERS
}

enum AircondSystemType {
  SPLIT
  CENTRAL
}

enum CentralAircondSize {
  SMALL
  MEDIUM
  LARGE
  VERY_LARGE
}

enum PaymentType {
  ONBOARD
  MONTHLY
  RESET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ApplianceType {
  AIRCOND
  CENTRAL_AIRCOND
  WATER_HEATER
  REFRIGERATOR
  WASHING_MACHINE
  TV
  LIGHTS
  WATER_PUMP
  RICE_COOKER
  MICROWAVE
  OVEN
  COMPUTER
  FAN
  IRON
  OTHER
}

enum ChainStatus {
  ONBOARD
  MONTHLY
  RESET
}

enum HealthBand {
  EXCELLENT
  GOOD
  FAIR
  ATTENTION
  CRITICAL
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  name               String
  phone              String?
  userType           UserType            @default(HOUSEHOLD)
  orgName            String?
  postcode           String?
  township           String?
  state              String?
  language           String              @default("EN")
  isActive           Boolean             @default(true)
  housingType        String?
  institutionType    InstitutionType?
  aircondSystemType  AircondSystemType?
  centralAircondSize CentralAircondSize?
  buildingAge        Int?
  floorAreaCategory  Int?
  lightType          Int?
  chainStatus        ChainStatus         @default(ONBOARD)
  lastBillingMonth   String?
  chainBrokenAt      DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  appliances         Appliance[]
  billingRecords     BillingRecord[]
  payments           Payment[]

  @@map("users")
}

model Appliance {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomName      String
  applianceType ApplianceType
  brand         String?
  hp            Float?
  inverter      Boolean       @default(false)
  wattage       Float?
  ageYears      Float         @default(0)
  qty           Int           @default(1)
  avgHoursDaily Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("appliances")
}

model BillingRecord {
  id                   String     @id @default(cuid())
  userId               String
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // BILLING PERIOD
  billingMonth         String
  billingPeriodDays    Int        @default(30)
  billingPeriodStart   String?
  billingPeriodEnd     String?

  // USAGE
  totalKwh             Float
  totalAmountMyr       Float
  cajSemasa            Float      @default(0)
  tunggakan            Float      @default(0)

  // BILL COMPONENTS
  generationCharge     Float      @default(0)
  capacityCharge       Float      @default(0)
  networkCharge        Float      @default(0)
  retailCharge         Float      @default(0)
  afaCharge            Float      @default(0)
  eeRebate             Float      @default(0)
  sstCharge            Float      @default(0)
  kwtbbCharge          Float      @default(0)
  latePaymentCharge    Float      @default(0)

  // RAW OCR
  rawOcrText           String?

  // 2-BILL 1-REPORT
  isReference          Boolean    @default(false)
  referenceMonth       String?

  // PAYMENT
  isUnlocked           Boolean    @default(false)
  paymentId            String?
  payment              Payment?   @relation(fields: [paymentId], references: [id])

  // TEASER RANGE — replaces single teaserAmount
  teaserLow            Float?
  teaserHigh           Float?

  // COVERAGE GAP
  coverageGapKwh       Float?
  coveragePercent      Int?

  // HEALTH SCORE
  healthScore          Int?
  healthBand           HealthBand?
  healthScoreThreshold Int?
  healthScoreTrend     Int?
  healthScoreBleeder   Int?
  healthScoreAfa       Int?
  healthScoreCause     Int?

  // INSTITUTIONAL
  expectedKwhMonthly   Float?
  wastedKwhMonthly     Float?
  wastedAmountMyr      Float?

  // REPORT
  reportData           Json?

  // MISSIONS
  missionKwhTarget     Float?
  missionKwhActual     Float?
  missionCompleted     Boolean?

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@map("billing_records")
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  billRef           String        @unique
  amountMyr         Float
  paymentType       PaymentType
  status            PaymentStatus @default(PENDING)
  toyyibpayBillCode String?
  toyyibpayOrderId  String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  billingRecords    BillingRecord[]

  @@map("payments")
}

model AfaRate {
  id        String   @id @default(cuid())
  month     String   @unique
  rateSen   Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("afa_rates")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}